# Application
NODE_ENV=test
HOST=127.0.0.1
PORT=3334
APP_KEY=test-app-key
APP_NAME=AdonisJS Monolith Template
APP_VERSION=1
API_PREFIX=/api
LOG_LEVEL=error

# Database
DB_CONNECTION=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=adonis_monolith_test
DB_DEBUG=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# CORS
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000

# Metrics
METRICS_ENABLED=true
