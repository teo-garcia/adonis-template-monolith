{
  "name": "adonis-template-monolith",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "teo-garcia",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "node ace build",
    "check": "pnpm lint:es:check && pnpm lint:ts && pnpm format:check && pnpm test",
    "commitlint": "commitlint --edit",
    "db:migrate": "node ace migration:run",
    "db:rollback": "node ace migration:rollback",
    "db:reset": "node ace migration:refresh",
    "db:status": "node ace migration:status",
    "dev": "node ace serve --hmr",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:es": "eslint . --fix",
    "lint:es:check": "eslint .",
    "lint:staged": "lint-staged",
    "lint:ts": "tsc --noEmit",
    "prepare": "husky",
    "start": "node bin/server.js",
    "start:prod": "node build/bin/server.js",
    "test": "node ace test",
    "test:functional": "node ace test functional",
    "test:unit": "node ace test unit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#services/*": "./app/services/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#database/*": "./database/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js"
  },
  "dependencies": {
    "@adonisjs/core": "^6.18.0",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/lucid": "^21.6.1",
    "@adonisjs/redis": "^9.2.0",
    "@vinejs/vine": "^3.0.1",
    "adonis-autoswagger": "^3.73.0",
    "luxon": "^3.7.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7.8.2",
    "@adonisjs/tsconfig": "^2.0.0",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.0",
    "@japa/api-client": "^3.1.0",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^4.0.0",
    "@japa/runner": "^5.0.0",
    "@swc/core": "1.15.32",
    "@teo-garcia/eslint-config-shared": "^0.4.0",
    "@teo-garcia/prettier-config-shared": "^0.2.9",
    "@types/node": "^24.7.0",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.0.0",
    "hot-hook": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.6.2",
    "ts-node-maintained": "^10.9.5",
    "typescript": "~6.0.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts",
      "./app/validators/*.ts"
    ]
  }
}
